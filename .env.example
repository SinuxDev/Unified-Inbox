NODE_ENV=development
PORT=3001

# Comma-separated browser origins allowed for CORS (frontend)
CORS_ORIGINS=http://localhost:3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=inbox
DATABASE_PASSWORD=inbox
DATABASE_NAME=futurewave_inbox

# Set to true when running Redis (e.g. docker compose up redis) for connector webhooks/queues
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-separate-from-access
JWT_REFRESH_EXPIRES_IN=7d

# Dev seed (npm run seed) — local/test only; blocked when NODE_ENV=production
SEED_DEV_USER_EMAIL=owner@example.com
SEED_DEV_USER_PASSWORD=Password123!
SEED_DEV_USER_DISPLAY_NAME=Dev Owner
SEED_DEV_ORG_NAME=Dev Organization
